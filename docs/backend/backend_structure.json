{
  "backend": {
    "framework": "Django",
    "architecture_pattern": "Modular Monolith with AI Processing Layer",
    "language": "Python"
  },

  "core_modules": {
    "authentication": {
      "description": "Handles user login, registration, and access control",
      "features": [
        "JWT or session-based authentication",
        "Role-based access (admin, examinee)"
      ]
    },

    "exam_management": {
      "description": "Manages exams, questions, and configurations",
      "features": [
        "Create exams",
        "Manage questions",
        "Assign examinees",
        "Schedule exams"
      ]
    },

    "exam_session": {
      "description": "Controls live exam sessions",
      "features": [
        "Session start and end",
        "Timer handling",
        "Answer submission tracking"
      ]
    },

    "monitoring": {
      "description": "Handles incoming video frames and monitoring requests",
      "features": [
        "Receive image frames from frontend",
        "Forward frames to AI module",
        "Return analysis results"
      ]
    },

    "behavior_analysis": {
      "description": "Processes AI outputs and computes behavioral scores",
      "features": [
        "Aggregate AI detection results",
        "Compute suspicion score",
        "Trigger anomaly flags"
      ]
    },

    "reporting": {
      "description": "Generates reports for administrators",
      "features": [
        "Behavior logs",
        "Session summaries",
        "Flagged event reports"
      ]
    }
  },

  "ai_integration": {
    "type": "Internal module or separate microservice",
    "pipeline": [
      "Receive frame",
      "Preprocess image (OpenCV)",
      "Run detection model (YOLO)",
      "Extract features (CNN)",
      "Face verification (FaceNet / ArcFace)",
      "Return structured results"
    ]
  },

  "api_design": {
    "type": "REST + WebSocket",
    "rest_endpoints": [
      {
        "endpoint": "/api/auth/login",
        "method": "POST",
        "description": "User authentication"
      },
      {
        "endpoint": "/api/exams",
        "method": "GET/POST",
        "description": "Retrieve or create exams"
      },
      {
        "endpoint": "/api/exams/{id}",
        "method": "GET",
        "description": "Get exam details"
      },
      {
        "endpoint": "/api/session/start",
        "method": "POST",
        "description": "Start exam session"
      },
      {
        "endpoint": "/api/monitor/frame",
        "method": "POST",
        "description": "Send image frame for analysis"
      },
      {
        "endpoint": "/api/reports",
        "method": "GET",
        "description": "Retrieve monitoring reports"
      }
    ],
    "websocket": {
      "purpose": "Real-time monitoring and feedback",
      "technology": "Django Channels",
      "events": [
        "frame_stream",
        "analysis_result",
        "alert_notification"
      ]
    }
  },

  "data_models": {
    "User": ["id", "name", "email", "role"],
    "Exam": ["id", "title", "duration", "created_by"],
    "Question": ["id", "exam_id", "content", "choices", "answer"],
    "Session": ["id", "user_id", "exam_id", "start_time", "end_time"],
    "Response": ["id", "session_id", "question_id", "answer"],
    "BehaviorLog": [
      "id",
      "session_id",
      "timestamp",
      "event_type",
      "score"
    ]
  },

  "processing_flow": [
    "Frontend captures frame",
    "Frame sent via API/WebSocket",
    "Backend receives frame",
    "AI module processes image",
    "Results passed to behavior analysis",
    "Score computed and stored",
    "Response returned to frontend"
  ],

  "performance": {
    "frame_handling": "1–5 FPS per user",
    "latency_target_ms": 300,
    "scalability_strategy": [
      "Async processing (Celery or Channels)",
      "Queue-based frame handling",
      "GPU acceleration for AI models"
    ]
  },

  "security": {
    "authentication": "JWT or session-based",
    "authorization": "Role-based access control",
    "data_protection": [
      "HTTPS encryption",
      "Secure API endpoints",
      "Input validation"
    ]
  }
}
