{
  "backend": {
    "framework": "Django",
    "architecture_pattern": "Feature-Based Modular Monolith with Layered Services",
    "language": "Python"
  },

  "core_architecture": {
    "pattern": "Feature-Based + Layered (Controller, Action, Service, Repository)",
    "description": "Each feature module encapsulates its own models, business logic, and API layer while following internal layering for separation of concerns"
  },

  "feature_modules": {
    "auth": {
      "description": "Handles authentication and user identity",
      "features": [
        "Login and registration",
        "JWT/session authentication",
        "Role-based access control"
      ]
    },

    "exams": {
      "description": "Manages exam creation and configuration",
      "features": [
        "Create and update exams",
        "Question management",
        "Assign examinees"
      ]
    },

    "session": {
      "description": "Controls live exam sessions",
      "features": [
        "Session lifecycle (start/end)",
        "Timer tracking",
        "Answer submission"
      ]
    },

    "monitoring": {
      "description": "Handles real-time monitoring and frame ingestion",
      "features": [
        "Receive frames via REST/WebSocket",
        "Stream frames to AI pipeline",
        "Emit real-time results"
      ]
    },

    "behavior": {
      "description": "Processes AI outputs into meaningful insights",
      "features": [
        "Behavior scoring engine",
        "Anomaly detection",
        "Alert triggering"
      ]
    },

    "reports": {
      "description": "Generates administrative reports",
      "features": [
        "Session summaries",
        "Behavior logs",
        "Flagged events"
      ]
    },

    "profile": {
      "description": "User profile management",
      "features": [
        "Update user details",
        "Profile retrieval"
      ]
    }
  },

  "layered_structure": {
    "controller": "Handles HTTP/WebSocket requests (views, consumers)",
    "action": "Single-use business operations (use cases)",
    "service": "Core business logic and orchestration",
    "repository": "Database access layer",
    "model": "Django ORM models"
  },

  "real_time_architecture": {
    "technology": "Django Channels",
    "flow": [
      "Frontend sends frame via WebSocket",
      "Consumer receives frame",
      "Action triggers AI pipeline",
      "Behavior service evaluates results",
      "Alert generated if needed",
      "Result sent back via WebSocket"
    ]
  },

  "ai_integration": {
    "type": "Internal module (extractable to microservice)",
    "pipeline": [
      "Preprocessing (OpenCV)",
      "Detection (YOLO)",
      "Feature extraction (CNN)",
      "Face recognition (FaceNet/ArcFace)",
      "Structured output"
    ]
  },

  "data_models": {
    "User": ["id", "name", "email", "role"],
    "Exam": ["id", "title", "duration", "created_by"],
    "Question": ["id", "exam_id", "content", "choices", "answer"],
    "Session": ["id", "user_id", "exam_id", "start_time", "end_time"],
    "Response": ["id", "session_id", "question_id", "answer"],
    "BehaviorLog": ["id", "session_id", "timestamp", "event_type", "score"],
    "Alert": ["id", "session_id", "type", "severity", "timestamp"]
  }
}
