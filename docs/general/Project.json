{
  "project": {
    "title": "Knowing Eye",
    "full_title": "A Full-Stack Session-Guided Web-Based Examination Platform with Integrated Behavior Monitoring Using Facial and Postural Analysis",
    "type": "Capstone Project",
    "date_started": "2026-03",
    "institution": {
      "name": "Legacy College of Compostela",
      "department": "Institute of Information Technology",
      "location": "Compostela, Davao de Oro, Philippines"
    },
    "team": [
      "Saturnino C. Ancog III",
      "Khrisha Marie O. Cavan",
      "Kervy N. Cadiente",
      "Twixt Jasley J. Tamera"
    ]
  },

  "vision": {
    "problem_statement": "Online examination systems lack reliable real-time behavioral monitoring, resulting in increased cheating risks and heavy reliance on manual supervision.",
    "solution": "A centralized web-based examination platform integrated with AI-powered behavioral monitoring using computer vision and deep learning.",
    "core_goal": "Enhance examination integrity, automate monitoring, and provide data-driven behavioral insights."
  },

  "objectives": {
    "general": "To design and develop a centralized web-based examination platform with integrated real-time behavioral monitoring.",
    "specific": [
      "Develop exam creation and management system",
      "Implement session-guided online examinations",
      "Capture and store video frames and session logs",
      "Analyze facial presence, gaze, and posture in real time",
      "Detect suspicious behaviors using AI models",
      "Generate behavioral reports and anomaly flags",
      "Provide an administrative analytics dashboard",
      "Evaluate system usability, functionality, and effectiveness"
    ]
  },

  "system_scope": {
    "included": [
      "Web-based examination platform",
      "Real-time webcam frame capture",
      "Facial detection and posture analysis",
      "Behavior scoring and anomaly detection",
      "Administrative dashboard and reports",
      "Session logging and storage"
    ],
    "excluded": [
      "Mobile application support",
      "External institutional system integration",
      "Biometric hardware devices",
      "Nationwide deployment"
    ],
    "target_users": [
      "Exam Administrators",
      "Examinees"
    ],
    "environment": "Controlled academic testing with simulated exam sessions"
  },

  "system_architecture": {
    "type": "Full-Stack Web Application with AI Processing Pipeline",
    "components": {
      "frontend": {
        "framework": "React",
        "language": "TypeScript",
        "responsibilities": [
          "User interface",
          "Exam interaction",
          "Webcam capture",
          "Frame extraction",
          "Real-time communication"
        ]
      },
      "backend": {
        "framework": "Django",
        "language": "Python",
        "responsibilities": [
          "REST API services",
          "Authentication and authorization",
          "Exam management",
          "Session handling",
          "Monitoring coordination"
        ]
      },
      "database": {
        "type": "Relational (PostgreSQL or MySQL)",
        "stores": [
          "Users",
          "Exams",
          "Questions",
          "Responses",
          "Session logs",
          "Behavior records"
        ]
      },
      "ai_module": {
        "deployment": "Backend-integrated module or microservice",
        "input": "Image frames from frontend",
        "processing": [
          "Face detection",
          "Posture detection",
          "Feature extraction",
          "Behavioral analysis"
        ],
        "output": [
          "Face presence status",
          "Gaze direction",
          "Posture classification",
          "Anomaly indicators"
        ]
      },
      "communication": {
        "REST": "Exam management, authentication, reporting",
        "WebSocket": "Real-time frame streaming and monitoring feedback"
      }
    }
  },

  "core_features": {
    "exam_management": [
      "Create and configure exams",
      "Schedule and deploy exams",
      "Manage examinees"
    ],
    "exam_execution": [
      "Session-guided exam flow",
      "Timed assessments",
      "Auto-save answers"
    ],
    "monitoring": [
      "Webcam frame capture",
      "Face detection",
      "Gaze tracking",
      "Posture analysis",
      "Identity verification"
    ],
    "analysis": [
      "Behavior scoring engine",
      "Anomaly detection",
      "Event flagging"
    ],
    "reporting": [
      "Behavioral reports",
      "Session review logs",
      "Administrative dashboard"
    ]
  },

  "behavior_scoring": {
    "inputs": [
      "Face presence",
      "Head movement",
      "Eye gaze direction",
      "Posture changes"
    ],
    "logic": "Rule-based scoring with potential machine learning enhancement",
    "output": [
      "Suspicion score",
      "Flagged behavioral events"
    ]
  },

  "ai_models": {
    "detection": "YOLO",
    "feature_extraction": "CNN",
    "face_recognition": ["FaceNet", "ArcFace"],
    "capabilities": [
      "Face detection",
      "Head pose estimation",
      "Eye gaze tracking",
      "Posture recognition",
      "Object detection"
    ]
  },

  "data_handling": {
    "inputs": [
      "Webcam image frames",
      "User interactions",
      "Exam responses"
    ],
    "outputs": [
      "Behavior logs",
      "Suspicion scores",
      "Flagged events",
      "Reports"
    ],
    "datasets": {
      "public": "Facial landmarks and posture datasets",
      "custom": "Mock exam session recordings with consent"
    }
  },

  "performance_constraints": {
    "target_latency_ms": 500,
    "processing_rate": "1–5 frames per second",
    "goal": "Near real-time behavioral analysis"
  },

  "security_and_privacy": {
    "measures": [
      "User authentication",
      "Role-based access control",
      "Encrypted communication (HTTPS)"
    ],
    "privacy": [
      "Explicit user consent for webcam usage",
      "Data used strictly for academic purposes",
      "Secure storage of sensitive data"
    ],
    "ethics": {
      "consent_required": true,
      "data_usage": "Academic research and system evaluation only",
      "anonymization": "Recommended for stored datasets"
    }
  },

  "workflow_summary": [
    "User logs in and starts exam session",
    "System verifies identity",
    "Webcam captures frames continuously",
    "Frames are sent to backend for analysis",
    "AI module processes behavioral data",
    "Behavior scoring engine evaluates actions",
    "Suspicious events are flagged",
    "Administrator reviews reports"
  ]
}
