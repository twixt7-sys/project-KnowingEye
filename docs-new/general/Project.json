    ]
  },

  "frontend_structure": {
    "core": ["router", "providers", "config", "hooks"],
    "features": ["auth", "exams", "session", "monitoring", "behavior", "dashboard", "reports", "profile"],
    "shared": ["components", "hooks", "utils", "types"],
    "pages": ["landing", "examiner", "examinee", "auth"]
  },

  "workflow_summary": [
    "User logs in and accesses dashboard",
    "Examiner or examinee selects an exam",
    "Exam session is started and timed",
    "Monitoring runs in parallel with exam delivery",
    "Responses are saved and submitted",
    "AI analysis evaluates behavior and flags events",
    "Reports and session summaries are generated"
  ],

