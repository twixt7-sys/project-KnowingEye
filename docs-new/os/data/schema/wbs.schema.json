{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WBS seed",
  "type": "object",
  "required": ["nodes"],
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "code", "title", "level"],
        "properties": {
          "id": { "type": "string" },
          "code": { "type": "string" },
          "title": { "type": "string" },
          "parent_id": { "type": ["string", "null"] },
          "level": { "type": "integer", "minimum": 1 },
          "owner": { "type": "string" },
          "status": { "type": "string" },
          "progress": { "type": "number", "minimum": 0, "maximum": 1 },
          "deliverable": { "type": "string" }
        }
      }
    }
  }
}
